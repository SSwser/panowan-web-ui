third_party/*/build/
third_party/*/__pycache__/
third_party/*/.pytest_cache/
third_party/*/.git/
third_party/*/models/
third_party/*/.mypy_cache/
third_party/*/.ruff_cache/

# Node modules and package managers
node_modules/
npm-debug.log
yarn.lock
pnpm-lock.yaml
