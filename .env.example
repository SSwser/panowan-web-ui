PORT=8000
GENERATION_TIMEOUT_SECONDS=1800
OUTPUT_DIR=/app/runtime/outputs
JOB_STORE_PATH=/app/runtime/jobs.json

# MODEL_ROOT=data/models             # Local path to store model weights
# data/runtime is mounted by docker-compose for generated videos and job state

# Model download settings (used by make download-models)
# HF_TOKEN=hf_xxx                    # Hugging Face token for higher rate limits
# HF_ENDPOINT=https://hf-mirror.com  # Mirror endpoint (useful in China)
# HF_MAX_WORKERS=8                   # Number of parallel download workers (default: 8)
# HF_HUB_DOWNLOAD_TIMEOUT=10         # Request timeout in seconds (default: 10)
# HF_HUB_ENABLE_HF_TRANSFER=0        # Enable faster C-based transfer (0=disabled, requires hf_transfer package)

# DOCTOR / 环境诊断
# make doctor — 检查环境（Docker、GPU、模型、.env、服务）

