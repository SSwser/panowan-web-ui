# ─── PanoWan Worker — example configuration ──────────────────────────────────
# Copy to .env and override values as needed (gitignored).
# Docker Compose auto-loads .env; unset variables fall back to app defaults.

# ─── Service ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Development mode (docker-compose-dev.yml) ──────────────────────────────
# DEV_MODE is managed by docker-compose-dev.yml
# DEV_SKIP_DOWNLOAD_MODELS=0   # dev only: 1=skip model/LoRA downloads at startup

# ─── Directories (container paths, usually left default) ───────────────────
# PANOWAN_SRC_DIR=./third_party/PanoWan
# MODEL_ROOT=./data/models        # host path for shared model cache mount
# PANOWAN_DIR=/app/PanoWan
# RUNTIME_DIR=/app/runtime
# WAN_MODEL_PATH=./models/Wan-AI/Wan2.1-T2V-1.3B
# LORA_CHECKPOINT_PATH=./models/PanoWan/latest-lora.ckpt
# OUTPUT_DIR=/app/runtime/outputs
# JOB_STORE_PATH=/app/runtime/jobs.json

# ─── Generation ─────────────────────────────────────────────────────────────
GENERATION_TIMEOUT_SECONDS=1800
DEFAULT_NUM_INFERENCE_STEPS=50
DEFAULT_WIDTH=896
DEFAULT_HEIGHT=448
# DEFAULT_PROMPT=A beautiful mountain landscape at sunset

# ─── Hugging Face — model download ──────────────────────────────────────────
# Personal token for higher rate limits
HF_TOKEN=
# Mirror endpoint (useful in China: https://hf-mirror.com)
HF_ENDPOINT=https://hf-mirror.com
# Faster C-based transfer (requires: pip install hf_transfer)
HF_HUB_ENABLE_HF_TRANSFER=0
HF_HUB_DOWNLOAD_TIMEOUT=10
HF_MAX_WORKERS=8

# ─── PyTorch & performance ──────────────────────────────────────────────────
PYTORCH_ALLOC_CONF=expandable_segments:True

# ─── vmtouch pagecache warm-up (0=off, 1=on; see logs at startup) ─────────
VMTOUCH_MODELS=1
